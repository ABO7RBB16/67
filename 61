local MessagingService = game:GetService("MessagingService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Stats = game:GetService("Stats")

-- مصفوفة المسارات (الطرق المتعددة)
local TOPICS = {"Extender", "BackupSync", "UrgentPulse", "NetworkLock", "DataFlow", "Cleaner", "Freezer", "Shield"}

-- وظيفة الحماية التلقائية من كود 285
local function MonitorHealth()
	task.spawn(function()
		while task.wait(0.5) do
			if Stats.Network.ServerIn:GetValue() > 500 or Stats.Internal.DataPing:GetValue() > 400 then
				collectgarbage("collect") -- تنظيف فوري عند خطر الفصل
			end
		end
	end)
end

-- استقبال الأوامر عبر 50 احتمال (تغطية شاملة لكل التوبيكات)
for _, topic in pairs(TOPICS) do
	MessagingService:SubscribeAsync(topic, function(msg)
		local data = tostring(msg.Data)
		
		if topic == "Cleaner" then
			collectgarbage("collect")
			debug.setmemorylimit(0) -- تحرير قيود الذاكرة
		elseif topic == "Freezer" then
			for _, p in pairs(workspace:GetDescendants()) do
				if p:IsA("BasePart") and not p.Anchored then p.Anchored = true end
			end
		elseif topic == "Shield" then
			settings().Network.IncomingReplicationLag = 0
		else
			-- وضع التمديد (Keep-Alive) عبر أي ريموت متاح
			local r = ReplicatedStorage:FindFirstChild(data, true)
			if r and r:IsA("RemoteEvent") then
				r:FireServer("STABILITY_PULSE", tick())
			end
		end
	end)
end

-- نظام Anti-AFK المتطور لجميع اللاعبين
game:GetService("Players").PlayerAdded:Connect(function(p)
	p.Idled:Connect(function()
		game:GetService("VirtualUser"):CaptureController()
		game:GetService("VirtualUser"):ClickButton2(Vector2.new(0,0))
	end)
end)

MonitorHealth()
